---
import { portfolioData } from "../data/portfolio-data";

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  keywords?: string[];
  type?: "website" | "profile";
}

const {
  title,
  description,
  ogImage = "/og-image.png",
  keywords,
  type = "website",
} = Astro.props;

const { personal } = portfolioData;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const ogImageUrl = new URL(ogImage, Astro.site).toString();

const defaultKeywords = [
  personal.name,
  personal.role,
  "Frontend Engineer",
  "React",
  "Next.js",
  "TypeScript",
  "Web Development",
  "Portfolio",
  "JavaScript",
];
const metaKeywords = (keywords ?? defaultKeywords).join(", ");

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: personal.name,
  jobTitle: personal.role,
  url: Astro.site?.toString(),
  email: personal.email,
  sameAs: [personal.github, personal.linkedin],
  knowsAbout: [
    "Frontend Development",
    "React",
    "Next.js",
    "TypeScript",
    "Web Performance",
    "SEO",
  ],
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />
<meta name="author" content={personal.name} />
<meta name="keywords" content={metaKeywords} />
<meta name="theme-color" content="#0a0a0a" />

<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalUrl} />

<meta property="og:type" content={type} />
<meta property="og:site_name" content={personal.name} />
<meta property="og:locale" content="en_US" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:alt" content={`${personal.name} — ${personal.role}`} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@tyrion7126" />
<meta name="twitter:creator" content="@tyrion7126" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageUrl} />
<meta
  name="twitter:image:alt"
  content={`${personal.name} — ${personal.role}`}
/>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" />
<link rel="sitemap" href="/sitemap-index.xml" />

<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
