---
import Layout from "../layouts/layout.astro";
import HeroSection from "../partials/hero-section.astro";
import MarqueeBanner from "../partials/marquee-banner.astro";
import ExperienceTimeline from "../partials/experience-timeline.astro";
import SkillsMatrix from "../partials/skills-matrix.astro";
import FooterCta from "../partials/footer-cta.astro";
import { ProjectGallery } from "../partials/project-gallery";
import { portfolioData } from "../data/portfolio-data";

const { personal } = portfolioData;
---

<Layout
  title={`${personal.name} — ${personal.role}`}
  description={personal.summary}
>
  <main>
    <HeroSection />
    <MarqueeBanner />
    <ExperienceTimeline />
    <ProjectGallery client:load />
    <SkillsMatrix />
  </main>
  <FooterCta />
</Layout>
