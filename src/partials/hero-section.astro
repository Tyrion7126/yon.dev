---
import { portfolioData, terminalStack } from "../data/portfolio-data";
import { HeroDecorations } from "../components/hero-decorations";
import { HeroTextReveal } from "../components/hero-text-reveal";
import { CustomCursor } from "../components/custom-cursor";

const { personal } = portfolioData;
---

<section class="relative min-h-[90vh] flex items-center py-20 px-6 md:px-12 lg:px-24 border-b-4 border-black overflow-hidden">
  <HeroDecorations client:load />
  <CustomCursor client:load />

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col justify-center">
      <HeroTextReveal
        client:load
        name={personal.name}
        role={personal.role}
        summary={personal.summary}
      />
      <div class="flex gap-4 flex-wrap">
        <a
          href={`mailto:${personal.email}`}
          class="inline-block px-6 py-3 font-heading font-bold text-lg border-4 border-black bg-primary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:rotate-[-1deg] transition-all duration-100 active:translate-x-[4px] active:translate-y-[4px] active:shadow-none active:rotate-0"
        >
          Get in touch →
        </a>
        <a
          href="#projects"
          class="inline-block px-6 py-3 font-heading font-bold text-lg border-4 border-black bg-secondary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] hover:rotate-[1deg] transition-all duration-100 active:translate-x-[4px] active:translate-y-[4px] active:shadow-none active:rotate-0"
        >
          View Work ↓
        </a>
      </div>
    </div>

    <div class="flex items-center justify-center lg:justify-end">
      <div
        class="w-full max-w-md border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] bg-border-dark text-bg-base overflow-hidden hover:rotate-[1deg] transition-transform duration-300"
      >
        <div class="flex items-center gap-2 px-4 py-3 bg-border-dark border-b-2 border-bg-base/20">
          <div class="w-3 h-3 rounded-full bg-primary border border-bg-base/30"></div>
          <div class="w-3 h-3 rounded-full bg-secondary border border-bg-base/30"></div>
          <div class="w-3 h-3 rounded-full bg-accent border border-bg-base/30"></div>
          <span class="ml-2 font-mono text-xs text-bg-base/60">~/daily-stack</span>
        </div>
        <div class="p-5 font-mono text-sm space-y-2">
          {
            terminalStack.map((line) => (
              <p class="text-bg-base/90 leading-relaxed">{line}</p>
            ))
          }
          <p class="text-accent animate-pulse mt-4">▊</p>
        </div>
      </div>
    </div>
  </div>
</section>
