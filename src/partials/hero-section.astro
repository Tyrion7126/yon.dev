          <rect x="194" y="0" width="4" height="50" fill="#1e1e1e"/>
        </svg>
        <span class="font-mono text-[9px] text-black/40 whitespace-nowrap">FSR-2024-PORTFOLIO</span>
      </div>
    </div>
  </div>
</section>
