---
import { portfolioData, terminalStack } from "../data/portfolio-data";
import { HeroDecorations } from "../components/hero-decorations";
import { HeroTextReveal } from "../components/hero-text-reveal";
import { CustomCursor } from "../components/custom-cursor";

const { personal } = portfolioData;
const buildDate = new Date().toISOString().replace("T", " ").slice(0, 19);
---

<section class="relative min-h-[90vh] flex items-center py-20 px-6 md:px-12 lg:px-24 border-b-4 border-black overflow-hidden">
  <HeroDecorations client:load />
  <CustomCursor client:load />

  <!-- Exposed HTML tags -->
  <span class="absolute top-4 left-6 font-mono text-xs text-black/20 select-none pointer-events-none z-0">&lt;section class="hero"&gt;</span>
  <span class="absolute bottom-4 right-6 font-mono text-xs text-black/20 select-none pointer-events-none z-0">&lt;/section&gt;</span>

  <!-- Build timestamp -->
  <span class="absolute top-4 right-6 font-mono text-[10px] text-black/30 select-none pointer-events-none z-0">
    BUILD {buildDate} UTC
  </span>

  <div class="relative z-10 grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 w-full max-w-7xl mx-auto">
    <div class="flex flex-col justify-center">
      <HeroTextReveal
        client:load
        name={personal.name}
        role={personal.role}
        summary={personal.summary}
      />
      <div class="flex gap-4 flex-wrap">
        <a
          href={`mailto:${personal.email}`}
          class="inline-block px-6 py-3 font-heading font-bold text-lg border-4 border-black bg-primary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all duration-100"
        >
          Get in touch →
        </a>
        <a
          href="#projects"
          class="inline-block px-6 py-3 font-heading font-bold text-lg border-4 border-black bg-secondary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all duration-100"
        >
          View Work ↓
        </a>
      </div>
    </div>

    <div class="flex flex-col items-center justify-center lg:items-end gap-8">
      <!-- Terminal card -->
      <div class="w-full max-w-md border-4 border-black shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] bg-border-dark text-bg-base overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 bg-border-dark border-b-2 border-bg-base/20">
          <div class="w-3 h-3 rounded-full bg-primary border border-bg-base/30"></div>
          <div class="w-3 h-3 rounded-full bg-secondary border border-bg-base/30"></div>
          <div class="w-3 h-3 rounded-full bg-accent border border-bg-base/30"></div>
          <span class="ml-2 font-mono text-xs text-bg-base/60">~/daily-stack</span>
        </div>
        <div class="p-5 font-mono text-sm space-y-2">
          {
            terminalStack.map((line) => (
              <p class="text-bg-base/90 leading-relaxed">{line}</p>
            ))
          }
          <p class="text-accent animate-pulse mt-4">▊</p>
        </div>
      </div>

      <!-- Barcode decoration -->
      <div class="w-full max-w-md flex items-center gap-4">
        <svg class="h-16 flex-1" viewBox="0 0 200 50" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect x="2" y="0" width="3" height="50" fill="#1e1e1e"/>
          <rect x="7" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="10" y="0" width="4" height="50" fill="#1e1e1e"/>
          <rect x="16" y="0" width="2" height="50" fill="#1e1e1e"/>
          <rect x="20" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="23" y="0" width="3" height="50" fill="#1e1e1e"/>
          <rect x="28" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="31" y="0" width="2" height="50" fill="#1e1e1e"/>
          <rect x="35" y="0" width="4" height="50" fill="#1e1e1e"/>
          <rect x="41" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="44" y="0" width="2" height="50" fill="#1e1e1e"/>
          <rect x="48" y="0" width="3" height="50" fill="#1e1e1e"/>
