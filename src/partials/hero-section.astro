          <rect x="69" y="0" width="3" height="50" fill="#1e1e1e"/>
          <rect x="74" y="0" width="2" height="50" fill="#1e1e1e"/>
          <rect x="78" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="81" y="0" width="4" height="50" fill="#1e1e1e"/>
          <rect x="87" y="0" width="1" height="50" fill="#1e1e1e"/>
          <rect x="90" y="0" width="3" height="50" fill="#1e1e1e"/>
          <rect x="95" y="0" width="2" height="50" fill="#1e1e1e"/>
          <rect x="99" y="0" width="1" height="50" fill="#1e1e1e"/>
