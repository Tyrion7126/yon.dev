---
import { portfolioData } from "../data/portfolio-data";
import { HeroTextReveal } from "../components/hero-text-reveal";
import { DraggableTerminal } from "../components/draggable-terminal";
import { SpinningBadge } from "../components/spinning-badge";
import { HeroDecorations } from "../components/hero-decorations";
import { CustomCursor } from "../components/custom-cursor";

const { personal } = portfolioData;
---

<section
  class="relative min-h-screen py-24 md:py-32 border-b-4 border-black overflow-hidden"
>
  <CustomCursor client:load />

  <!-- Exposed HTML tags -->
  <span
    class="absolute top-4 left-4 font-mono text-xs text-black/20 select-none pointer-events-none z-0"
    >&lt;section class="hero"&gt;</span
  >
  <span
    class="absolute bottom-4 right-4 font-mono text-xs text-black/20 select-none pointer-events-none z-0"
    >&lt;/section&gt;</span
  >

  <!-- System init badge (top left) -->
  <div class="absolute top-6 left-6 z-20">
    <div
      class="bg-bg-base border-4 border-black px-4 py-2 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
    >
      <span
        class="font-mono text-[10px] font-bold tracking-wider text-border-dark block"
        >[SYS.INIT: JAKARTA, ID]</span
      >
      <span class="font-mono text-[9px] text-border-dark/60 block"
        >NODE_ENV=production</span
      >
    </div>
  </div>

  <!-- Spinning experience badge -->
  <div class="absolute top-20 right-[10%] z-10 hidden lg:block">
    <SpinningBadge client:load />
  </div>

  <!-- Decorative geometric shapes (stars, arrows, doodles) -->
  <HeroDecorations client:load />

  <!-- Main poster content -->
  <div class="relative z-10 max-w-7xl mx-auto w-full px-4 md:px-8">
    <!-- Massive typography -->
    <div class="relative mb-12 md:mb-16">
      <HeroTextReveal client:load name={personal.name} role={personal.role} />
    </div>

    <!-- Oversized CTAs -->
    <div class="flex gap-4 md:gap-6 flex-wrap relative z-20">
      <a
        href={`mailto:${personal.email}`}
        class="inline-block py-3 px-6 md:py-5 md:px-10 lg:py-6 lg:px-12 font-heading font-bold text-lg md:text-xl lg:text-2xl border-2 md:border-4 border-black bg-primary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all duration-100"
      >
        Get in touch →
      </a>
      <a
        href="#projects"
        class="inline-block py-3 px-6 md:py-5 md:px-10 lg:py-6 lg:px-12 font-heading font-bold text-lg md:text-xl lg:text-2xl border-2 md:border-4 border-black bg-secondary shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] md:shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-none hover:translate-x-[4px] hover:translate-y-[4px] transition-all duration-100"
      >
        View Work ↓
      </a>
    </div>

    <!-- Summary text block -->
    <div class="mt-10 max-w-xl">
      <p
        class="text-fluid-body font-body text-border-dark bg-bg-base border-2 md:border-4 border-black px-3 py-3 md:px-5 md:py-4 leading-relaxed shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] md:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]"
      >
        {personal.summary}
      </p>
    </div>
  </div>

  <!-- Draggable terminal (overlapping, positioned absolutely) -->
  <div class="hidden md:block">
    <DraggableTerminal client:load />
  </div>
</section>
