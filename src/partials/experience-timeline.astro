                    />
                  </svg>
                  <span class="font-mono text-[9px] whitespace-nowrap">
                    {exp.id.toUpperCase()}
                  </span>
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
