---
import { portfolioData } from "../data/portfolio-data";

const { experience } = portfolioData;
const bgColors = [
  "bg-primary",
  "bg-secondary",
  "bg-accent",
  "bg-bg-base",
  "bg-primary/60",
  "bg-secondary/60",
  "bg-accent/60",
];
---

<section id="experience" class="bg-bg-base border-b-4 border-black">
  <div class="py-20 px-6 md:px-12 lg:px-24">
    <h2 class="font-heading mb-16">Experience</h2>

    <div class="max-w-5xl mx-auto">
      {
        experience.map((exp, index) => (
          <div
            class:list={[
              "sticky border-4 border-black p-8 md:p-10 mb-6",
              "shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]",
              bgColors[index % bgColors.length],
            ]}
            style={`top: calc(10vh + ${index * 2}rem); z-index: ${index + 1};`}
          >
            <div class="flex flex-col md:flex-row md:items-start md:justify-between gap-4 mb-6">
              <div>
                <h3 class="text-3xl md:text-4xl font-heading font-bold leading-tight mb-2">
                  {exp.role}
                </h3>
                <p class="font-mono text-sm uppercase tracking-wider text-border-dark/70">
                  {exp.company} · {exp.location}
                </p>
              </div>
              <span class="font-mono text-sm border-4 border-black px-4 py-2 bg-bg-base shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] whitespace-nowrap self-start">
                {exp.period}
              </span>
            </div>
            <ul class="space-y-2">
              {exp.achievements.map((item) => (
                <li class="flex gap-3 text-sm font-body text-border-dark leading-relaxed">
                  <span class="shrink-0 mt-1.5 w-2 h-2 bg-black" />
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>
</section>
