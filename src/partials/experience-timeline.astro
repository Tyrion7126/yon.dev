---
import { portfolioData } from "../data/portfolio-data";

const { experience } = portfolioData;
const bgColors = ["bg-primary", "bg-secondary", "bg-bg-base", "bg-accent"];
---

<section
  id="experience"
  class="bg-graph-paper border-b-4 border-border-dark relative"
>
  <span
    class="absolute top-4 left-6 font-mono text-xs text-border-dark/20 select-none pointer-events-none"
    >&lt;section id="experience"&gt;</span
  >
  <span
    class="absolute bottom-4 right-6 font-mono text-xs text-border-dark/20 select-none pointer-events-none"
    >&lt;/section&gt;</span
  >

  <div class="py-20 px-4 md:px-8">
    <div class="max-w-7xl mx-auto w-full">
      <div class="mb-16">
        <span
          class="font-mono text-xs md:text-sm border-2 border-border-dark px-2 py-1 inline-block bg-bg-base mb-3 md:mb-4 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)]"
          >FILE_REF: 001</span
        >
        <h2
          class="relative font-heading text-[clamp(2.5rem,8vw,7rem)] leading-[0.85] text-secondary [-webkit-text-stroke:1px_#1E1E1E] md:[-webkit-text-stroke:2px_#1E1E1E] lg:[-webkit-text-stroke:3px_#1E1E1E]"
        >
          <span
            class="absolute top-0 left-0 translate-x-1 translate-y-1 md:translate-x-2 md:translate-y-2 text-border-dark select-none pointer-events-none"
            aria-hidden="true"
          >
            <span class="block">WORK</span>
            <span class="block">EXPERIENCE</span>
          </span>
          <span class="relative">
            <span class="block">WORK</span>
            <span class="block">EXPERIENCE</span>
          </span>
        </h2>
      </div>

      <div class="max-w-6xl mx-auto">
        {
          experience.map((exp, index) => (
            <div
              class:list={[
                "sticky border-4 border-black mb-8",
                "shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]",
                bgColors[index % bgColors.length],
              ]}
              style={`top: calc(10vh + ${index * 2.5}rem); z-index: ${index + 1};`}
            >
              {/* Folder Tab */}
              <div class="absolute top-[-2px] left-8 -translate-y-full">
                <div class="bg-border-dark text-bg-base border-4 border-border-dark border-b-0 px-5 py-2 font-mono text-xs font-bold tracking-wider">
                  {exp.period}
                </div>
              </div>

              {/* Corner alignment markers */}
              <span class="absolute top-2 left-2 font-mono text-[10px] text-border-dark/20 leading-none select-none pointer-events-none">
                +
              </span>
              <span class="absolute top-2 right-2 font-mono text-[10px] text-border-dark/20 leading-none select-none pointer-events-none">
                +
              </span>
              <span class="absolute bottom-2 left-2 font-mono text-[10px] text-border-dark/20 leading-none select-none pointer-events-none">
                +
              </span>
              <span class="absolute bottom-2 right-2 font-mono text-[10px] text-border-dark/20 leading-none select-none pointer-events-none">
                +
              </span>

              <div class="p-8 md:p-10 pt-10">
                {/* Status badge */}
                <div class="absolute top-4 right-6">
                  {exp.status === "ACTIVE" ? (
                    <span class="font-mono text-[10px] font-black uppercase px-3 py-1 bg-secondary border-4 border-border-dark shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] tracking-widest">
                      ACTIVE
                    </span>
                  ) : (
                    <span class="font-mono text-[10px] font-black uppercase px-3 py-1 bg-bg-base border-4 border-border-dark shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] tracking-widest">
                      ARCHIVED
                    </span>
                  )}
                </div>

                {/* Main content grid */}
                <div class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-8 items-start">
                  {/* Left: Oversized typography */}
                  <div>
                    <h3 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-[0.95] mb-3">
                      {exp.role}
                    </h3>
                    <p class="font-mono text-sm uppercase tracking-wider text-border-dark/70 mb-1">
                      {exp.company}
                    </p>
                    <p class="font-mono text-xs text-border-dark/50">
                      {exp.location}
                    </p>
                  </div>

                  {/* Right: Description highlight block */}
                  <div class="bg-bg-base border-4 border-border-dark p-5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                    <p class="text-sm font-body text-border-dark leading-relaxed">
                      {exp.description}
                    </p>
                  </div>
                </div>

                {/* Barcode decoration */}
                <div class="mt-6 flex items-center gap-3 opacity-30 pointer-events-none select-none">
                  <svg
                    class="h-6 flex-1 max-w-[200px]"
                    viewBox="0 0 200 20"
                    fill="none"
                    xmlns="http://www.w3.org/2000/svg"
