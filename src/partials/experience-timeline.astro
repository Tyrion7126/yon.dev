---
import { portfolioData } from "../data/portfolio-data";

const { experience } = portfolioData;
const bgColors = ["bg-primary", "bg-secondary", "bg-bg-base", "bg-accent"];
---

<section id="experience" class="bg-bg-base border-b-4 border-black relative">
  <span class="absolute top-4 left-6 font-mono text-xs text-black/20 select-none pointer-events-none">&lt;section id="experience"&gt;</span>
  <span class="absolute bottom-4 right-6 font-mono text-xs text-black/20 select-none pointer-events-none">&lt;/section&gt;</span>

  <div class="py-20 px-6 md:px-12 lg:px-24">
    <h2 class="font-heading mb-16">Experience</h2>

    <div class="max-w-6xl mx-auto">
      {
        experience.map((exp, index) => (
          <div
            class:list={[
              "sticky border-4 border-black mb-8 relative",
              "shadow-[8px_8px_0px_0px_rgba(0,0,0,1)]",
              bgColors[index % bgColors.length],
            ]}
            style={`top: calc(10vh + ${index * 2.5}rem); z-index: ${index + 1};`}
          >
            {/* Folder Tab */}
            <div class="absolute -top-[2px] left-8 -translate-y-full">
              <div class="bg-border-dark text-bg-base border-4 border-black border-b-0 px-5 py-2 font-mono text-xs font-bold tracking-wider">
                {exp.period}
              </div>
            </div>

            {/* Corner alignment markers */}
            <span class="absolute top-2 left-2 font-mono text-[10px] text-black/20 leading-none select-none pointer-events-none">+</span>
            <span class="absolute top-2 right-2 font-mono text-[10px] text-black/20 leading-none select-none pointer-events-none">+</span>
            <span class="absolute bottom-2 left-2 font-mono text-[10px] text-black/20 leading-none select-none pointer-events-none">+</span>
            <span class="absolute bottom-2 right-2 font-mono text-[10px] text-black/20 leading-none select-none pointer-events-none">+</span>

            <div class="p-8 md:p-10 pt-10">
              {/* Status badge */}
              <div class="absolute top-4 right-6">
                {exp.status === "ACTIVE" ? (
                  <span class="font-mono text-[10px] font-black uppercase px-3 py-1 bg-secondary border-4 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] tracking-widest">
                    ACTIVE
                  </span>
                ) : (
                  <span class="font-mono text-[10px] font-black uppercase px-3 py-1 bg-bg-base border-4 border-black shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] tracking-widest">
                    ARCHIVED
                  </span>
                )}
              </div>

              {/* Main content grid */}
              <div class="grid grid-cols-1 md:grid-cols-[1fr_1.2fr] gap-8 items-start">
                {/* Left: Oversized typography */}
                <div>
                  <h3 class="text-3xl md:text-4xl lg:text-5xl font-heading font-bold leading-[0.95] mb-3">
                    {exp.role}
                  </h3>
                  <p class="font-mono text-sm uppercase tracking-wider text-border-dark/70 mb-1">
                    {exp.company}
                  </p>
                  <p class="font-mono text-xs text-border-dark/50">
                    {exp.location}
                  </p>
                </div>

                {/* Right: Description highlight block */}
                <div class="bg-bg-base border-4 border-black p-5 shadow-[4px_4px_0px_0px_rgba(0,0,0,1)]">
                  <p class="text-sm font-body text-border-dark leading-relaxed">
                    {exp.description}
                  </p>
                </div>
              </div>

              {/* Barcode decoration */}
              <div class="mt-6 flex items-center gap-3 opacity-30 pointer-events-none select-none">
                <svg class="h-6 flex-1 max-w-[200px]" viewBox="0 0 200 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <rect x="0" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="4" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="7" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="12" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="15" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="19" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="24" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="27" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="31" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="34" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="39" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="43" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="46" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="51" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="54" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="58" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="63" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="66" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="70" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="73" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="78" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="82" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="85" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="90" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="93" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="97" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="102" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="105" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="109" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="112" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="117" y="0" width="2" height="20" fill="currentColor"/>
                  <rect x="121" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="124" y="0" width="3" height="20" fill="currentColor"/>
                  <rect x="129" y="0" width="1" height="20" fill="currentColor"/>
                  <rect x="132" y="0" width="2" height="20" fill="currentColor"/>
                </svg>
                <span class="font-mono text-[9px] whitespace-nowrap">{exp.id.toUpperCase()}</span>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
