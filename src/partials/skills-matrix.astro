---
import { portfolioData } from "../data/portfolio-data";

const { skills } = portfolioData;
const allItems = skills.flatMap((s) => s.items);
const doubledItems = [...allItems, ...allItems];
---

<section id="skills" class="bg-bg-base border-b-4 border-black overflow-hidden">
  <div class="py-20 px-6 md:px-12 lg:px-24">
    <h2 class="font-heading mb-12">Skills & Tools</h2>

    <div class="relative -mx-6 md:-mx-12 lg:-mx-24">
      <div class="flex animate-marquee whitespace-nowrap gap-4 px-6">
        {
          doubledItems.map((skill, i) => (
            <span
              class="inline-flex items-center px-5 py-3 font-mono text-base font-medium border-4 border-black shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] bg-bg-base hover:bg-primary hover:translate-x-[2px] hover:translate-y-[2px] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] transition-all duration-100 shrink-0"
              key={`${skill}-${i}`}
            >
              {skill}
            </span>
          ))
        }
      </div>
    </div>

    <div class="mt-12 space-y-8">
      {
        skills.map((group) => (
          <div>
            <h3 class="font-heading text-lg font-bold mb-4 border-b-2 border-black pb-2">
              {group.category}
            </h3>
            <div class="flex flex-wrap gap-3">
              {group.items.map((item) => (
                <div class="border-4 border-black px-4 py-2 shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] bg-bg-base hover:shadow-none hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-100">
                  <span class="font-mono text-sm font-bold">{item}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
