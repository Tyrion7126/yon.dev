---
import { portfolioData } from "../data/portfolio-data";

const { personal } = portfolioData;
---

<footer class="bg-secondary border-t-4 border-black">
	<div class="py-20 px-6 md:px-12 lg:px-24 text-center">
		<h2 class="font-heading mb-6">Let's Build Something</h2>
		<p class="text-fluid-body font-body text-border-dark/80 max-w-xl mx-auto mb-10 leading-relaxed">
			I'm always open to discussing new projects, creative ideas, or opportunities to be part of
			something great.
		</p>

		<div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
			<a
				href={`mailto:${personal.email}`}
				class="inline-block px-8 py-4 font-heading font-bold text-xl border-4 border-black bg-primary shadow-[8px_8px_0px_0px_rgba(0,0,0,1)] hover:shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-100 active:translate-x-[4px] active:translate-y-[4px] active:shadow-none"
			>
				{personal.email}
			</a>
		</div>

		<div class="flex items-center justify-center gap-4">
			<a
				href={personal.github}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center px-5 py-3 font-mono text-sm font-bold border-4 border-black bg-bg-base shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-100 active:translate-x-[4px] active:translate-y-[4px] active:shadow-none"
			>
				GitHub
			</a>
			<a
				href={personal.linkedin}
				target="_blank"
				rel="noopener noreferrer"
				class="inline-flex items-center px-5 py-3 font-mono text-sm font-bold border-4 border-black bg-bg-base shadow-[4px_4px_0px_0px_rgba(0,0,0,1)] hover:shadow-[2px_2px_0px_0px_rgba(0,0,0,1)] hover:translate-x-[2px] hover:translate-y-[2px] transition-all duration-100 active:translate-x-[4px] active:translate-y-[4px] active:shadow-none"
			>
				LinkedIn
			</a>
		</div>

		<p class="mt-12 font-mono text-xs text-border-dark/60">
			© {new Date().getFullYear()} {personal.name}. Built with Astro, React & Tailwind CSS.
		</p>
	</div>
</footer>
