---
const items = [
  "REACT",
  "ASTRO",
  "TYPESCRIPT",
  "GO",
  "ELYSIA",
  "NEXT.JS",
  "DOCKER",
  "BUN",
  "TAILWIND",
  "VIM",
];
const separator = " • ";
const text = items.join(separator) + separator;
---

<div
  class="border-y-4 border-black bg-primary overflow-hidden py-4 select-none"
  aria-hidden="true"
>
  <div class="flex animate-marquee whitespace-nowrap">
    <span class="font-heading text-3xl md:text-5xl font-bold tracking-tight text-black">
      {text}{text}{text}{text}
    </span>
  </div>
</div>
